{
  "manifest_version": 3,
  "name": "Pixmori",
  "description": "Minimal MVP productivity companion with a pixel pet.",
  "version": "0.1.0",
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Pixmori"
  },
  "background": {
    "service_worker": "assets/service-worker.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "sidePanel",
    "alarms",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "externally_connectable": {
    "matches": [
      "http://localhost/*",
      "http://localhost:5173/*",
      "https://pixmori.app/*"
    ]
  }
}
